! get rid of this annoying log messsage
%CLOUD_MGMT_MGRD-5-CURL_FETCH_ERR: Switch 1 R0/0: cloud_mgmt_mgrd: Curl Fetch ERR: Could not resolve host config-1337.mera

(config)#no service cloud-mgmt connect


! dns client
dns-lookup vrf Mgmt-vrf hostname feralpacket.org 192.0.2.1 query A 
show dns-lookup hostname feralpacket.org


! test-throughput
test-throughput tcp-client 192.0.2.1 ?
  dscp         Specify DSCP value in ASCII/Numeric
  mode         Mode of measurement
  num-windows  Number of windows for the various modes of operation
  port         Server transport port
  receive      Operate in receive mode
  timeout      Measurement time in seconds
  vrf          VPN Routing/Forwarding parameters
  window-span  Duration of measurement window(s) in seconds
  <cr>         <cr>


! shut / no shut an interface
bounce interface gi0/0


!
service log-hidden

! this doesn't show error counters on the stack ports
! TODO - find the show platform command that does
sh switch stack-ports detail


! if ZTP is allowed to run, the switch will configure itself for IPv6.
! if ZTP is interrupted as soon as boot up is complete, the switch will not have any IPv6 configuration.
! this has caused problems when trying to license 9300s.  the dns query would return both A and AAAA records.
!   the switch would then only use the AAAA record and try to connect to the licensing server via IPv6.
! to remove IPv6:
!
int vlan 1
 no ipv6 enable
 no ipv6 dhcp client request vendor
 no ipv6 address dhcp
 no ipv6 address autoconfig
!
int gi0/0
 no ipv6 enable
 no ipv6 dhcp client request vendor
 no ipv6 address dhcp
 no ipv6 address autoconfig
! no negotiation auto
!
no ipv6 nd cache expire refresh
no ipv6 unicast-routing
!
! this thing is still enabled by default
no ip forward-protocol nd

